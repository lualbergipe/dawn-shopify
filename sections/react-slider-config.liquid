{{ 'react-slider-config.css' | asset_url | stylesheet_tag }}

<div id="slider-config-app">
  <!-- La app React se montará aquí -->
</div>

<!-- Cargar React y la app -->
<script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
<script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>

<script>
  // Verificar que React se carga
  console.log('React disponible:', typeof React !== 'undefined');
  console.log('ReactDOM disponible:', typeof ReactDOM !== 'undefined');

  // Configuración de la app React
  const SliderConfigApp = () => {
    const [config, setConfig] = React.useState({
      autoplay: true,
      speed: 3000,
      primaryColor: '#ffffff',
      showArrows: true,
      showPagination: false,
      title: 'Mi Slider Personalizado',
    });

    const [isLoading, setIsLoading] = React.useState(false);
    const [message, setMessage] = React.useState({ type: '', text: '' });

    React.useEffect(() => {
      loadConfig();
    }, []);

    const loadConfig = () => {
      const savedConfig = localStorage.getItem('slider-config');
      if (savedConfig) {
        setConfig(JSON.parse(savedConfig));
      }
    };

    const saveConfig = async () => {
      setIsLoading(true);
      try {
        await new Promise((resolve) => setTimeout(resolve, 1000));
        localStorage.setItem('slider-config', JSON.stringify(config));
        setMessage({ type: 'success', text: 'Configuración guardada exitosamente!' });
        console.log('Configuración guardada:', config);
      } catch (error) {
        setMessage({ type: 'error', text: 'Error al guardar' });
      } finally {
        setIsLoading(false);
      }
    };

    const updateConfig = (key, value) => {
      setConfig((prev) => ({ ...prev, [key]: value }));
    };

    return React.createElement(
      'div',
      { className: 'react-app-container' },
      React.createElement('h1', null, 'Configurador de Slider (React)'),

      message.text &&
        React.createElement(
          'div',
          {
            className: `message ${message.type}`,
          },
          message.text
        ),

      React.createElement(
        'div',
        { className: 'config-form' },
        React.createElement(
          'div',
          { className: 'form-group' },
          React.createElement('label', null, 'Título:'),
          React.createElement('input', {
            type: 'text',
            value: config.title,
            onChange: (e) => updateConfig('title', e.target.value),
          })
        ),

        React.createElement(
          'div',
          { className: 'form-group' },
          React.createElement('label', null, 'Autoplay:'),
          React.createElement('input', {
            type: 'checkbox',
            checked: config.autoplay,
            onChange: (e) => updateConfig('autoplay', e.target.checked),
          })
        ),

        React.createElement(
          'div',
          { className: 'form-group' },
          React.createElement('label', null, `Velocidad: ${config.speed}ms`),
          React.createElement('input', {
            type: 'range',
            min: 1000,
            max: 10000,
            step: 500,
            value: config.speed,
            onChange: (e) => updateConfig('speed', parseInt(e.target.value)),
          })
        ),

        React.createElement(
          'div',
          { className: 'form-group' },
          React.createElement('label', null, 'Color:'),
          React.createElement('input', {
            type: 'color',
            value: config.primaryColor,
            onChange: (e) => updateConfig('primaryColor', e.target.value),
          })
        ),

        React.createElement(
          'div',
          { className: 'form-group' },
          React.createElement('label', null, 'Mostrar Flechas:'),
          React.createElement('input', {
            type: 'checkbox',
            checked: config.showArrows,
            onChange: (e) => updateConfig('showArrows', e.target.checked),
          })
        ),

        React.createElement(
          'div',
          { className: 'form-group' },
          React.createElement('label', null, 'Mostrar Puntos:'),
          React.createElement('input', {
            type: 'checkbox',
            checked: config.showPagination,
            onChange: (e) => updateConfig('showPagination', e.target.checked),
          })
        ),

        React.createElement(
          'button',
          {
            onClick: saveConfig,
            disabled: isLoading,
            className: 'save-btn',
          },
          isLoading ? 'Guardando...' : 'Guardar Configuración'
        )
      ),

      React.createElement(
        'div',
        { className: 'preview' },
        React.createElement('h3', null, 'Vista Previa'),
        React.createElement(
          'div',
          {
            className: 'preview-slider',
            style: {
              background: `linear-gradient(45deg, ${config.primaryColor}, #f0f0f0)`,
              height: '200px',
              borderRadius: '8px',
              display: 'flex',
              alignItems: 'center',
              justifyContent: 'center',
              color: '#333',
              position: 'relative',
            },
          },
          React.createElement(
            'div',
            { style: { textAlign: 'center' } },
            React.createElement('h4', null, config.title),
            React.createElement('p', null, `Autoplay: ${config.autoplay ? 'Sí' : 'No'} | Velocidad: ${config.speed}ms`)
          ),

          config.showArrows &&
            React.createElement(
              'div',
              {
                style: {
                  position: 'absolute',
                  left: '20px',
                  top: '50%',
                  transform: 'translateY(-50%)',
                  background: 'rgba(0,0,0,0.5)',
                  color: 'white',
                  width: '30px',
                  height: '30px',
                  borderRadius: '50%',
                  display: 'flex',
                  alignItems: 'center',
                  justifyContent: 'center',
                  cursor: 'pointer',
                },
              },
              '‹'
            ),

          config.showArrows &&
            React.createElement(
              'div',
              {
                style: {
                  position: 'absolute',
                  right: '20px',
                  top: '50%',
                  transform: 'translateY(-50%)',
                  background: 'rgba(0,0,0,0.5)',
                  color: 'white',
                  width: '30px',
                  height: '30px',
                  borderRadius: '50%',
                  display: 'flex',
                  alignItems: 'center',
                  justifyContent: 'center',
                  cursor: 'pointer',
                },
              },
              '›'
            ),

          config.showPagination &&
            React.createElement(
              'div',
              {
                style: {
                  position: 'absolute',
                  bottom: '20px',
                  left: '50%',
                  transform: 'translateX(-50%)',
                  display: 'flex',
                  gap: '10px',
                },
              },
              React.createElement('div', {
                style: {
                  width: '10px',
                  height: '10px',
                  borderRadius: '50%',
                  background: config.primaryColor,
                  cursor: 'pointer',
                },
              }),
              React.createElement('div', {
                style: {
                  width: '10px',
                  height: '10px',
                  borderRadius: '50%',
                  background: 'rgba(255,255,255,0.5)',
                  cursor: 'pointer',
                },
              })
            )
        )
      )
    );
  };

  // Función para inicializar React
  function initializeReactApp() {
    console.log('Intentando montar React...');

    // Verificar que el elemento existe
    const appElement = document.getElementById('slider-config-app');
    console.log('Elemento encontrado:', appElement);

    if (appElement && typeof ReactDOM !== 'undefined') {
      try {
        const root = ReactDOM.createRoot(appElement);
        root.render(React.createElement(SliderConfigApp));
        console.log('React montado exitosamente');
      } catch (error) {
        console.error('Error al montar React:', error);
        // Fallback: mostrar contenido básico
        appElement.innerHTML = `
          <h1>Configurador de Slider (Fallback)</h1>
          <p>Error al cargar React. Mostrando versión básica.</p>
          <div class="config-form">
            <div class="form-group">
              <label>Título:</label>
              <input type="text" id="title-input" value="Mi Slider">
            </div>
            <button onclick="saveBasicConfig()">Guardar</button>
          </div>
        `;
      }
    } else {
      console.error('No se pudo encontrar el elemento o React no está disponible');
      if (appElement) {
        appElement.innerHTML = '<p>Error: React no está disponible</p>';
      }
    }
  }

  // Inicializar cuando el DOM esté listo
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeReactApp);
  } else {
    initializeReactApp();
  }

  // Escuchar eventos del theme editor
  document.addEventListener('shopify:section:load', function (event) {
    console.log('Sección cargada:', event.detail);
    // Inicializar para cualquier sección que contenga nuestro elemento
    setTimeout(initializeReactApp, 100);
  });

  // También escuchar cuando se selecciona la sección
  document.addEventListener('shopify:section:select', function (event) {
    console.log('Sección seleccionada:', event.detail);
    // Inicializar para cualquier sección
    setTimeout(initializeReactApp, 100);
  });

  // Escuchar cambios en el DOM (para cuando se agregan secciones dinámicamente)
  const observer = new MutationObserver(function (mutations) {
    mutations.forEach(function (mutation) {
      if (mutation.type === 'childList') {
        mutation.addedNodes.forEach(function (node) {
          if (node.nodeType === 1 && node.querySelector && node.querySelector('#slider-config-app')) {
            console.log('Elemento React detectado en DOM');
            setTimeout(initializeReactApp, 100);
          }
        });
      }
    });
  });

  observer.observe(document.body, {
    childList: true,
    subtree: true,
  });

  // Función de fallback
  function saveBasicConfig() {
    const title = document.getElementById('title-input').value;
    localStorage.setItem(
      'slider-config',
      JSON.stringify({
        title: title,
        autoplay: true,
        speed: 3000,
        primaryColor: '#ffffff',
        showArrows: true,
        showPagination: false,
      })
    );
    alert('Configuración guardada: ' + title);
  }
</script>

{% schema %}
{
  "name": "React Slider Config",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Configurador React"
    }
  ],
  "presets": [
    {
      "name": "React Slider Config"
    }
  ]
}
{% endschema %}
